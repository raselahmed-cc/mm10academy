# MM10 Academy - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ========================
# Environment
# ========================
WP_ENVIRONMENT_TYPE=production

# ========================
# Database
# ========================
DB_NAME=mm10academy_db
DB_USER=your_db_user
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PREFIX=wp_

# ========================
# Site URLs
# ========================
WP_SITEURL=https://mm10academy.com
WP_HOME=https://mm10academy.com

# ========================
# Authentication Keys & Salts
# Generate at: https://api.wordpress.org/secret-key/1.1/salt/
# ========================
AUTH_KEY=generate-unique-phrase-here
SECURE_AUTH_KEY=generate-unique-phrase-here
LOGGED_IN_KEY=generate-unique-phrase-here
NONCE_KEY=generate-unique-phrase-here
AUTH_SALT=generate-unique-phrase-here
SECURE_AUTH_SALT=generate-unique-phrase-here
LOGGED_IN_SALT=generate-unique-phrase-here
NONCE_SALT=generate-unique-phrase-here

# ========================
# Redis (if available)
# ========================
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# ========================
# Advanced Options
# ========================
DISABLE_WP_CRON=false
DISALLOW_FILE_MODS=false
