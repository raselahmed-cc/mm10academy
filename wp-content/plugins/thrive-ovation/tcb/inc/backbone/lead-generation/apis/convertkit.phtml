<# if ( api.get('supports_tags') ) { #>
<div class="api-field">
	<div class="field-description">
		<?php echo __( 'Tags', 'thrive-cb' ); ?>
	</div>
	<div class="tvd-select2-dropdown-parent"></div>
	<div class="tvd-input-field">
		<select id="tve-lg-select-tags" multiple name="tags" tabindex="-1" class="select2-hidden-accessible tve-api-extra">
			<#
			// Get all available tags from API
			var availableTags = api.get('tags') || [];
			var tagsConfig = api.getConfig('tags');
			var selectedTags = [];

			// Parse currently selected tags
			if ( tagsConfig ) {
				selectedTags = typeof tagsConfig === 'string' ? tagsConfig.split(',').map(function(tag) { return tag.trim(); }) : [tagsConfig];
			}

			// Sort available tags alphabetically by tag name
			var sortedTags = availableTags.slice().sort(function(a, b) {
				return a.name.toLowerCase().localeCompare(b.name.toLowerCase());
			});

			// Display all available tags as options (sorted alphabetically)
			_.each( sortedTags, function( tag ) {
				var isSelected = selectedTags.indexOf(tag.name) !== -1;
			#>
			<option value="<#=tag.name#>"<# if (isSelected) { #> selected="selected"<# } #>><#=tag.name#></option>
			<#
			}, this );

			// Also add any selected tags that might not be in the available tags list (custom tags)
			_.each( selectedTags, function( tag ) {
				var cleanTag = String(tag).trim();
				if ( cleanTag && !_.findWhere(availableTags, {name: cleanTag}) ) {
			#>
			<option value="<#=cleanTag#>" selected="selected"><#=cleanTag#></option>
			<#
				}
			}, this );
			#>
		</select>
	</div>
</div>
