<div class="api-field">
	<div class="control-grid" style="align-items: center; justify-content: flex-start;">
		<div class="field-description" style="margin: 5px 0;">
			<?php echo __( 'Tags', 'thrive-cb' ); ?>
		</div>
		<span class="click tve-refresh-api-list" data-fn="forceGet" data-tooltip="<?php echo __( 'Refresh', 'thrive-cb' ); ?>" data-side="top" style="position: relative; top: 2px;"> <?php tcb_icon( 'redo-regular' ) ?></span>
	</div>
	<div class="tvd-select2-dropdown-parent"></div>
	<div class="tvd-input-field">
		<select id="tve-lg-select-tags" multiple name="tags" tabindex="-1" class="tve-api-extra">
			<#
			// Get all available tags from API
			var availableTags = api.get('tags') || [];
			var tagsConfig = api.getConfig('tags');
			var selectedTags = [];
			var migratedFromOldFormat = false;

			// BACKWARD COMPATIBILITY: Check for old format first
			if ( ! tagsConfig && api.getConfig('list') ) {
				// Old format: 'list' contained numeric tag ID
				var oldTagId = api.getConfig('list');
				var tagMapping = api.get('tag_mapping') || {};

				// Try to find tag name from mapping
				if ( tagMapping[oldTagId] ) {
					selectedTags = [tagMapping[oldTagId]];
					migratedFromOldFormat = true;

					// Auto-migrate to new format
					api.setConfig({
						tags: tagMapping[oldTagId],
						list: null
					});
				}
				// Fallback: match from available tags by ID
				else {
					var foundTag = _.find(availableTags, function(tag) {
						return tag.id == oldTagId;
					});

					if ( foundTag && foundTag.text ) {
						selectedTags = [foundTag.text];
						migratedFromOldFormat = true;
						api.setConfig({
							tags: foundTag.text,
							list: null
						});
					}
				}
			}
			// New format: Parse comma-separated tag names
			else if ( tagsConfig ) {
				selectedTags = typeof tagsConfig === 'string' ?
					tagsConfig.split(',').map(function(tag) { return tag.trim(); }) :
					[tagsConfig];
			}

			// Sort available tags alphabetically by tag name
			var sortedTags = availableTags.slice().sort(function(a, b) {
				return a.text.toLowerCase().localeCompare(b.text.toLowerCase());
			});

			// Display all available tags as options (sorted alphabetically)
			_.each( sortedTags, function( tag ) {
				var isSelected = selectedTags.indexOf(tag.text) !== -1;
			#>
			<option value="<#=tag.text#>"<# if (isSelected) { #> selected="selected"<# } #>><#=tag.text#></option>
			<#
			}, this );

			// Also add any selected tags that might not be in the available tags list (custom tags)
			_.each( selectedTags, function( tag ) {
				var cleanTag = String(tag).trim();
				if ( cleanTag && !_.findWhere(availableTags, {text: cleanTag}) ) {
			#>
			<option value="<#=cleanTag#>" selected="selected"><#=cleanTag#></option>
			<#
				}
			}, this );
			#>
		</select>
	</div>
</div>
